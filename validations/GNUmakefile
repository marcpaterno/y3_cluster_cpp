# --------------------------------------------------------------------
# Costanzi-2026 Part I targets.  Generated by emit_validation_tsv.py
# (in the sibling RichnessSelection repo) using the smoke datablock dump
# under $(SMOKE_OUT).  Targets are gitignored (see global *.tsv rule);
# regenerate with `make data` after a fresh smoke run.
# --------------------------------------------------------------------
RS_VAL      := /pscratch/sd/j/jesteves/github/RichnessSelection/validations
SMOKE_OUT   := ../smoke_sel_runs/smoke_full_sel_cp_camb_output
COSTANZI_DIR := ../validation-data/costanzi2026

# 14 observables: 5 wired (real comparisons against the Python ref),
# 9 still emit NotImplementedError -- the Rmd treats those as "TBD".
COSTANZI_TSVS := \
    $(COSTANZI_DIR)/cp_camb_pk.tsv \
    $(COSTANZI_DIR)/hmf_tinker.tsv \
    $(COSTANZI_DIR)/halo_bias.tsv \
    $(COSTANZI_DIR)/num_counts.tsv \
    $(COSTANZI_DIR)/num_counts_sel.tsv \
    $(COSTANZI_DIR)/p_operator.tsv \
    $(COSTANZI_DIR)/bsel_plateaus.tsv \
    $(COSTANZI_DIR)/bsel_theta.tsv \
    $(COSTANZI_DIR)/sigma_1h.tsv \
    $(COSTANZI_DIR)/dsigma_1h.tsv \
    $(COSTANZI_DIR)/shear_1h.tsv \
    $(COSTANZI_DIR)/sigma_prj.tsv \
    $(COSTANZI_DIR)/dsigma_prj.tsv \
    $(COSTANZI_DIR)/shear_prj.tsv \
    $(COSTANZI_DIR)/sigma_prj_cuhre.tsv \
    $(COSTANZI_DIR)/dsigma_prj_cuhre.tsv \
    $(COSTANZI_DIR)/shear_prj_cuhre.tsv

DATAFILES += $(COSTANZI_TSVS)

# Pattern rule: TSV stem == --observable flag value.
$(COSTANZI_DIR)/%.tsv: $(RS_VAL)/emit_validation_tsv.py
	mkdir -p $(@D)
	cd $(RS_VAL) && \
	  python emit_validation_tsv.py \
	    --observable $* \
	    --smoke-out $(abspath $(SMOKE_OUT)) \
	    --out $(abspath $@)

RFNAME=physics_validation_y1rerun.Rmd

all: html
data: $(DATAFILES)
html: physics_validation.html
pdf: physics_validation.pdf
word: physics_validation.docx

physics_validation.html: $(RFNAME) $(DATAFILES)
	Rscript -e "rmarkdown::render('$<', 'html_document', '$@', clean = FALSE)"

physics_validation.pdf: $(RFNAME) $(DATAFILES)
	Rscript -e "rmarkdown::render('$<', 'pdf_document', '$@', clean = FALSE)"

physics_validation.docx: $(RFNAME) $(DATAFILES)
	Rscript -e "rmarkdown::render('$<', 'word_document', '$@', clean = FALSE)"

clean:
	rm -f *.md *.html *.pdf *.docx
	rm -f figure/*
	rm -rf physics_validation_files/
	rm -f ../validation-data/*.out
	rm -rf ../release-build/data/*.out
	rm -rf ../masses_test_output
	rm -rf ../sdss_analysis_output
	rm -rf ../y1_analysis_output
	rm -rf ../OUTPUT
	rm -rf physics_validation_cache/

../validation-data/omega_z_sdss.out: ../release-build/test/omega_z_sdss_test
	cd ../release-build/test && ./omega_z_sdss_test

# mfp: It appears to me that cosmosis_tests/mf_tinker_test.py requires the file
# ../release-build/test/test_hmf_z0_z03.dat. The file ../release-build/test/test_hmf_z0_z03.dat has been
# checked into the git repository, so for now we only have our target depend on
# that file.
../validation-data/masses_test.out: ../cosmosis_tests/mf_tinker_test.py ../cosmosis_tests/masses_test.ini ../test/test_hmf_z0_z03.dat ../cosmosis_tests/values/values_comp.ini
